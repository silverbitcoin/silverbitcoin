# SilverBitcoin Public RPC Node Configuration
# This configuration is optimized for running a free public RPC endpoint
# with community access and appropriate rate limits

[network]
# Network listening address (bind to all interfaces for public access)
listen_address = "0.0.0.0:9000"

# External address advertised to peers
external_address = "YOUR_PUBLIC_IP:9000"

# P2P communication address
p2p_address = "0.0.0.0:9001"

# Maximum number of peer connections
max_peers = 100

# Seed nodes for initial peer discovery
seed_nodes = [
    "/ip4/seed1.silverbitcoin.org/tcp/9000/p2p/12D3KooW...",
    "/ip4/seed2.silverbitcoin.org/tcp/9000/p2p/12D3KooW...",
]

[consensus]
# Public RPC nodes are NOT validators
is_validator = false

# Snapshot interval in milliseconds (default: 480ms)
snapshot_interval_ms = 480

# Batch size limits
max_batch_transactions = 500
max_batch_size_bytes = 524288  # 512 KB

[storage]
# Database path
db_path = "./data/public-rpc-db"

# Snapshot retention period in days (keep more for public access)
snapshot_retention_days = 90

# Enable automatic pruning of old data
enable_pruning = true

# Object cache size in bytes (2GB for better query performance)
object_cache_size = 2147483648

[api]
# JSON-RPC HTTP address (bind to all interfaces for public access)
json_rpc_address = "0.0.0.0:9545"

# WebSocket address for subscriptions (bind to all interfaces)
websocket_address = "0.0.0.0:9546"

# Enable CORS for browser-based applications
enable_cors = true

# Allowed CORS origins (empty = allow all, recommended for public RPC)
cors_origins = []

# Rate limit per client IP (100 requests per second as per requirement 31.4)
rate_limit_per_second = 100

# Maximum batch request size (limit to prevent abuse)
max_batch_size = 50

# Maximum request size in bytes (128KB)
max_request_size = 131072

# Maximum response size in bytes (10MB)
max_response_size = 10485760

# Maximum concurrent connections (higher for public access)
max_connections = 5000

# Request timeout in seconds
request_timeout_seconds = 30

[metrics]
# Prometheus metrics endpoint (internal only, not exposed publicly)
prometheus_address = "127.0.0.1:9184"

# Enable metrics collection
enable_metrics = true

# Metrics update interval in seconds
update_interval_seconds = 1

[logging]
# Log level: info for production, debug for troubleshooting
level = "info"

# Log output path
log_path = "./logs/public-rpc-node.log"

# Enable JSON structured logging for better parsing
json_format = true

# Log rotation
max_log_size_mb = 500
max_log_files = 30

[execution]
# Number of worker threads for parallel execution
# Adjust based on available CPU cores
worker_threads = 16

# Enable NUMA-aware memory allocation
numa_aware = true

# Fuel price (MIST per fuel unit)
fuel_price = 1000

[gpu]
# Enable GPU acceleration if available (improves performance)
enable_gpu = true

# GPU backend: opencl, cuda, metal, auto
backend = "auto"

# Minimum batch size for GPU execution
min_batch_size = 100

[public_rpc]
# Public RPC specific settings

# Enable public access mode (additional security and monitoring)
enabled = true

# Maximum queries per IP per hour (additional long-term rate limit)
max_queries_per_hour = 360000  # 100 req/s * 3600 seconds

# Enable query result caching (improves performance for repeated queries)
enable_query_cache = true

# Query cache size in bytes (1GB)
query_cache_size = 1073741824

# Query cache TTL in seconds
query_cache_ttl = 60

# Enable request logging for monitoring and abuse detection
enable_request_logging = true

# Block abusive IPs automatically
enable_auto_blocking = true

# Auto-block threshold (requests per second before blocking)
auto_block_threshold = 500

# Auto-block duration in seconds
auto_block_duration = 3600  # 1 hour

# Whitelist IPs (never rate limited or blocked)
whitelist_ips = []

# Blacklist IPs (always blocked)
blacklist_ips = []

# Enable health check endpoint
enable_health_check = true

# Health check path
health_check_path = "/health"

# Enable status page
enable_status_page = true

# Status page path
status_page_path = "/status"

# Maximum subscription count per WebSocket connection
max_subscriptions_per_connection = 10

# WebSocket connection timeout in seconds
websocket_timeout_seconds = 300

# Enable DDoS protection
enable_ddos_protection = true

# Connection rate limit (new connections per second)
connection_rate_limit = 50

