# SilverBitcoin Node Configuration with Monitoring
# This example shows how to configure metrics and health check endpoints

[network]
listen_address = "0.0.0.0:9000"
external_address = "127.0.0.1:9000"
p2p_address = "0.0.0.0:9001"
max_peers = 50
seed_nodes = []

[consensus]
is_validator = false
snapshot_interval_ms = 480
max_batch_transactions = 500
max_batch_size_bytes = 524288

[storage]
db_path = "./data/db"
snapshot_retention_days = 30
enable_pruning = true
object_cache_size = 1073741824  # 1 GB

[api]
json_rpc_address = "0.0.0.0:9545"
websocket_address = "0.0.0.0:9546"
enable_cors = true
cors_origins = []
rate_limit_per_second = 100
max_batch_size = 50

[metrics]
# Prometheus metrics endpoint
prometheus_address = "0.0.0.0:9184"
enable_metrics = true
# Update metrics at least once per second (requirement 15.3)
update_interval_seconds = 1

[logging]
level = "info"
log_path = "./logs/node.log"
json_format = false
max_log_size_mb = 100
max_log_files = 10

[execution]
worker_threads = 16
numa_aware = false
fuel_price = 1000

[gpu]
enable_gpu = false
backend = "auto"
min_batch_size = 100

# Monitoring Endpoints:
# - Prometheus metrics: http://localhost:9184/metrics
# - Health check: http://localhost:9185/health
# - Readiness probe: http://localhost:9185/ready
# - Liveness probe: http://localhost:9185/live
#
# Metrics tracked (requirement 15.2):
# - Transaction throughput
# - Consensus latency
# - Peer connection count
# - Storage utilization
# - CPU, memory, disk usage
# - File descriptor usage
#
# Resource warnings (requirement 15.4):
# - CPU usage > 80%
# - Memory usage > 80%
# - Disk usage > 80%
# - File descriptor usage > 80%
