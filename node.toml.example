# SilverBitcoin Node Configuration Example
# Copy this file to node.toml and customize for your setup

[network]
# Network listening address
listen_address = "0.0.0.0:9000"

# External address advertised to peers
external_address = "YOUR_PUBLIC_IP:9000"

# P2P communication address
p2p_address = "0.0.0.0:9001"

# Maximum number of peer connections
max_peers = 50

# Seed nodes for initial peer discovery
seed_nodes = [
    "/ip4/seed1.silverbitcoin.org/tcp/9000/p2p/12D3KooW...",
    "/ip4/seed2.silverbitcoin.org/tcp/9000/p2p/12D3KooW...",
]

[consensus]
# Enable validator mode (requires staking)
is_validator = false

# Path to validator key file (required if is_validator = true)
# validator_key_path = "/etc/silver/validator.key"

# Validator stake amount (minimum 1,000,000 SBTC)
# stake_amount = 1000000

# Snapshot interval in milliseconds (default: 480ms)
snapshot_interval_ms = 480

# Batch size limits
max_batch_transactions = 500
max_batch_size_bytes = 524288  # 512 KB

[storage]
# Database path
db_path = "./data/db"

# Snapshot retention period in days
snapshot_retention_days = 30

# Enable automatic pruning of old data
enable_pruning = true

# Object cache size in bytes (default: 1GB)
object_cache_size = 1073741824

[api]
# JSON-RPC HTTP address
json_rpc_address = "0.0.0.0:9545"

# WebSocket address for subscriptions
websocket_address = "0.0.0.0:9546"

# Enable CORS
enable_cors = true

# Allowed CORS origins (empty = allow all)
cors_origins = []

# Rate limit per client IP (requests per second)
rate_limit_per_second = 100

# Maximum batch request size
max_batch_size = 50

[metrics]
# Prometheus metrics endpoint
prometheus_address = "0.0.0.0:9184"

# Enable metrics collection
enable_metrics = true

# Metrics update interval in seconds
update_interval_seconds = 1

[logging]
# Log level: trace, debug, info, warn, error
level = "info"

# Log output path
log_path = "./logs/node.log"

# Enable JSON structured logging
json_format = false

# Log rotation
max_log_size_mb = 100
max_log_files = 10

[execution]
# Number of worker threads for parallel execution
worker_threads = 16

# Enable NUMA-aware memory allocation
numa_aware = true

# Fuel price (MIST per fuel unit)
fuel_price = 1000

[gpu]
# Enable GPU acceleration (requires GPU support compiled in)
enable_gpu = false

# GPU backend: opencl, cuda, metal, auto
backend = "auto"

# Minimum batch size for GPU execution
min_batch_size = 100
